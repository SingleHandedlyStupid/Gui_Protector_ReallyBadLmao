local simple_protect = {}

function simple_protect:Getcg(): Instance
	return game:GetService("CoreGui")
end

function g(len)
	local sta = "aopqcblmnghituvwxyzjkrsdef"
	local string = ""
	for i=1,(len or math.random(12,24)) do
	local r = math.random(1,#sta)
	string..=sta:sub(r,r)
	end
	return string
end

--ui: ScreenGui, type: StringType ("Core" or "Named")
function simple_protect:ProtectGUI(ui:ScreenGui,type:string) : ScreenGui
	if typeof(type)~="string" then return end
	type = type:lower()
	if type=="core" then
		ui.Parent = simple_protect:Getcg()
	elseif type=="named" then
		ui.Parent=game.Players.LocalPlayer.PlayerGui
		ui.Name = g() .. g()
	elseif type=="hide" then
		ui.Name = simple_protect:Getcg():GetChildren()[math.random(1,#simple_protect:Getcg():GetChildren())].Name .."Å"
		simple_protect:ProtectGUI(ui,"core")
	end
	return ui
end

return simple_protect
